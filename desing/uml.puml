        + buscarLibroPorIsbn(isbn : String) : Libro
        + buscarLibroPorTitulo(titulo : String) : ListaEnlazada<Libro>
        + registrarUsuario(usuario : Usuario) : void
        + buscarUsuario(id : String) : Usuario
        + registrarPrestamo(idUsuario : String, isbn : String) : Prestamo
        + procesarDevolucion(idPrestamo : String) : void
        + generarAlertas() : ListaEnlazada<Prestamo>
        + ordenarCatalogoPorTitulo() : ListaEnlazada<Libro>
        + ordenarCatalogoPorAutor() : ListaEnlazada<Libro>
        + getPrestamosActivos() : ListaEnlazada<Prestamo>
        - cargarDatosDePrueba() : void
