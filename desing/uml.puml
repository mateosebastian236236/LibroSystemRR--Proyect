' ══════════════════════════════════════════
' PAQUETE: tads
' ══════════════════════════════════════════
package "librosystemrr.tads" #0d1f2d {

    class Nodo<T> <<generic>> {
        - dato : T
        - siguiente : Nodo<T>
        + Nodo(dato : T)
        + getDato() : T
        + getSiguiente() : Nodo<T>
        + setDato(dato : T) : void
        + setSiguiente(siguiente : Nodo<T>) : void
    }

    class ListaEnlazada<T> {
        - cabeza : Nodo<T>
        - tamanio : int
        + ListaEnlazada()
        + agregar(dato : T) : void
        + agregarAlInicio(dato : T) : void
        + eliminar(dato : T) : boolean
        + obtener(indice : int) : T
        + buscar(dato : T) : T
        + getTamanio() : int
        + estaVacia() : boolean
        + toArray() : T[]
    }

    class Cola<T> {
        - frente : Nodo<T>
        - fin : Nodo<T>
        - tamanio : int
        + Cola()
        + encolar(dato : T) : void
        + desencolar() : T
        + getFronte() : T
        + getTamanio() : int
        + estaVacia() : boolean
    }

    class Pila<T> {
        - tope : Nodo<T>
        - tamanio : int
        + Pila()
        + apilar(dato : T) : void
        + desapilar() : T
        + getTope() : T
        + getTamanio() : int
        + estaVacia() : boolean
    }

    note bottom of Nodo
        Base interna de ListaEnlazada,
        Cola y Pila. Implementación
        propia sin librerías externas.
    end note
}

' ══════════════════════════════════════════
' PAQUETE: tads.arbol
' ══════════════════════════════════════════
package "librosystemrr.tads.arbol" #0d2d1f {

    class NodoBST {
        - libro : Libro
        - izquierdo : NodoBST
        - derecho : NodoBST
        + NodoBST(libro : Libro)
        + getLibro() : Libro
        + getIzquierdo() : NodoBST
        + getDerecho() : NodoBST
        + setIzquierdo(nodo : NodoBST) : void
        + setDerecho(nodo : NodoBST) : void
    }

    class CatalogoBST implements Buscable {
        - raiz : NodoBST
        + CatalogoBST()
        + insertar(libro : Libro) : void
        + buscarPorIsbn(isbn : String) : Libro
        + buscarPorTitulo(titulo : String) : ListaEnlazada<Libro>
        + eliminar(isbn : String) : boolean
        + inorden() : ListaEnlazada<Libro>
        + estaVacio() : boolean
        + getTamanio() : int
        .. «recursive» ..
        - insertarRec(nodo : NodoBST, libro : Libro) : NodoBST
        - buscarRec(nodo : NodoBST, isbn : String) : Libro
        - inordenRec(nodo : NodoBST, lista : ListaEnlazada) : void
        - eliminarRec(nodo : NodoBST, isbn : String) : NodoBST
    }

    note right of CatalogoBST
        Métodos privados «recursive»:
        O(log n) promedio
        O(n) peor caso (árbol degenerado)
    end note
}

' ══════════════════════════════════════════
' PAQUETE: algoritmos
' ══════════════════════════════════════════
package "librosystemrr.algoritmos" #1a2d0d {

    class AlgoritmosBusqueda <<utility>> {
        .. O(n) — lista enlazada ..
        + {static} busquedaLineal(lista : ListaEnlazada<T>, clave : T) : T
        + {static} buscarPorTituloLineal(lista : ListaEnlazada<Libro>, titulo : String) : ListaEnlazada<Libro>
        + {static} buscarVencidos(lista : ListaEnlazada<Prestamo>) : ListaEnlazada<Prestamo>
        .. O(log n) — arreglo ordenado ..
        + {static} busquedaBinaria(arr : Libro[], clave : String) : int
        .. O(log n) prom / O(n) peor — «recursive» ..
        + {static} buscarEnBST(raiz : NodoBST, isbn : String) : Libro
    }

    class AlgoritmosOrdenamiento <<utility>> {
        .. O(n log n) — «recursive» estable ..
        + {static} mergeSort(lista : ListaEnlazada<Libro>) : ListaEnlazada<Libro>
        + {static} ordenarPorTitulo(lista : ListaEnlazada<Libro>) : ListaEnlazada<Libro>
        + {static} ordenarPorAutor(lista : ListaEnlazada<Libro>) : ListaEnlazada<Libro>
        + {static} ordenarPorFechaDevolucion(lista : ListaEnlazada<Prestamo>) : ListaEnlazada<Prestamo>
        .. O(n log n) prom / O(n²) peor — in-place ..
        + {static} quickSort(arr : Libro[], inicio : int, fin : int) : void
        .. «recursive» — métodos privados ..
        - {static} mergeSortRec(lista : ListaEnlazada<Libro>) : ListaEnlazada<Libro>
        - {static} merge(izq : ListaEnlazada<Libro>, der : ListaEnlazada<Libro>) : ListaEnlazada<Libro>
        - {static} quickSortRec(arr : Libro[], inicio : int, fin : int) : void
        - {static} partition(arr : Libro[], inicio : int, fin : int) : int
    }

    note bottom of AlgoritmosOrdenamiento
        mergeSort → estable, ideal para
        ListaEnlazada<T>
        quickSort → in-place, ideal para
        arreglos Libro[]
    end note
}

