' PAQUETE: excepciones
' ══════════════════════════════════════════
package "librosystemrr.excepciones" #2d1010 {

    abstract class LibroSystemException {
        - mensaje : String
        - timestamp : Date
        + getMensaje() : String
        + getTimestamp() : Date
    }

    class LibroNoEncontradoException extends LibroSystemException {
        + LibroNoEncontradoException(isbn : String)
    }

    class LibroNoDisponibleException extends LibroSystemException {
        + LibroNoDisponibleException(isbn : String)
    }

    class UsuarioNoEncontradoException extends LibroSystemException {
        + UsuarioNoEncontradoException(id : String)
    }

    class UsuarioConDeudaException extends LibroSystemException {
        + UsuarioConDeudaException(id : String)
    }

    class CatalogoVacioException extends LibroSystemException {
        + CatalogoVacioException()
    }
}

