package "librosystemrr.interfaces" #0d1a2e {

    interface Buscable {
        + buscarPorIsbn(isbn : String) : Libro
        + buscarPorTitulo(titulo : String) : ListaEnlazada<Libro>
    }

    interface Ordenable<T> {
        + compareTo(otro : T) : int
    }
}

