package "librosystemrr.modelos" #1a1a2d {

    class Libro implements Ordenable {
        - isbn : String
        - titulo : String
        - autor : String
        - anioPublicacion : int
        - disponible : boolean
        + Libro(isbn : String, titulo : String, autor : String, anio : int)
        + getIsbn() : String
        + getTitulo() : String
        + getAutor() : String
        + isDisponible() : boolean
        + setDisponible(disponible : boolean) : void
        + compareTo(otro : Libro) : int
        + toString() : String
    }

    abstract class Usuario {
        # id : String
        # nombre : String
        # correo : String
        # prestamosActivos : Cola<Prestamo>
        # historialPrestamos : Pila<Prestamo>
        + Usuario(id : String, nombre : String, correo : String)
        + getId() : String
        + getNombre() : String
        + getCorreo() : String
        + getPrestamosActivos() : Cola<Prestamo>
        + getHistorialPrestamos() : Pila<Prestamo>
        + {abstract} getTipo() : String
        + toString() : String
    }

    class Lector extends Usuario {
        - limitePrestamos : int
        - {static} LIMITE_DEFAULT : int = 3
        + Lector(id : String, nombre : String, correo : String)
        + puedePrestar() : boolean
        + getTipo() : String
        + getMultasTotal() : double
        + tieneDeudas() : boolean
    }

    class Bibliotecario extends Usuario {
        - codigoEmpleado : String
        + Bibliotecario(id : String, nombre : String, correo : String, codigo : String)
        + getTipo() : String
        + registrarLibro(libro : Libro) : void
        + procesarDevolucion(prestamo : Prestamo) : void
        + generarReporte() : ListaEnlazada<Prestamo>
    }

    class AyudanteBibliotecario extends Usuario {
        - codigoEmpleado : String
        + AyudanteBibliotecario(id : String, nombre : String, correo : String, codigo : String)
        + getTipo() : String
        + registrarPrestamo(usuario : Usuario, libro : Libro) : Prestamo
        + procesarDevolucion(prestamo : Prestamo) : void
    }

    class Prestamo {
        - id : String
        - libro : Libro
        - usuario : Usuario
        - fechaPrestamo : Date
        - fechaDevolucion : Date
        - devuelto : boolean
        - multa : Multa
        + Prestamo(id : String, libro : Libro, usuario : Usuario, fechaDevolucion : Date)
        + getId() : String
        + getLibro() : Libro
        + getUsuario() : Usuario
        + getFechaDevolucion() : Date
        + isDevuelto() : boolean
        + isVencido() : boolean
        + getDiasRetraso() : int
        + devolver() : void
        + getMulta() : Multa
        + toString() : String
    }

    class Multa {
        - monto : double
        - pagada : boolean
        - fechaPago : Date
        - {static} MONTO_POR_DIA : double = 0.50
        + Multa(diasRetraso : int)
        + getMonto() : double
        + isPagada() : boolean
        + pagar() : void
        + getFechaPago() : Date
        + toString() : String
    }
}

